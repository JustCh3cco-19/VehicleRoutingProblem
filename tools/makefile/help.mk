	@printf "  %-42s | %s\n" "exp_strong_mpi" "Strong scaling MPI: N fisso, OMP fisso, ranks variabili"
	@printf "  %-42s | %s\n" "exp_strong_hybrid" "Strong scaling ibrido: N fisso, coppie (ranks,threads)"
	@printf "  %-42s | %s\n" "exp_weak_mpi" "Weak scaling MPI: coppie (ranks,n) da EXP_WEAK_MPI_PAIRS"
	@printf "  %-42s | %s\n" "exp_weak_hybrid" "Weak scaling ibrido: triple (ranks,threads,n) da EXP_WEAK_HYBRID_TRIPLETS"
	@printf "  %-42s | %s\n" "exp_cuda_scaling_input" "CUDA problem-size sweep su una GPU fissa"
	@printf "  %-42s | %s\n" "exp_cuda_scaling_ants" "Sweep legacy sul numero di formiche (non incluso in exp_cuda_all)"
	@printf "  %-42s | %s\n" "exp_seq_for_cuda" "Test sequenziale (non scaling) per confronto CUDA"
	@printf "  %-42s | %s\n" "exp_cuda_all" "Esegue solo il problem-size sweep CUDA a GPU fissa"
	@printf "  %-42s | %s\n" "exp_practical_cpu" "Campagna pratica completa lato CPU (skip CUDA), pronta per job batch"
	@printf "  %-42s | %s\n" "exp_practical_gpu" "Campagna pratica lato GPU (solo sezioni CUDA), pronta per job batch"
	@printf "  %-42s | %s\n\n" "exp_all" "Esegue in sequenza: exp_strong_openmp, exp_weak_openmp, exp_strong_mpi, exp_strong_hybrid, exp_weak_mpi, exp_weak_hybrid"
	@printf "VARIABILI PER solve_*:\n"
	@printf "  %-60s | %s\n" "RESULTS_ROOT=results" "Root unica risultati (solve)"
	@printf "  %-60s | %s\n" "SOLVE_OUT_DIR=$(RESULTS_ROOT)/solve_manifest" "Directory base output solve_*"
	@printf "  %-60s | %s\n" "SOLVE_CSV_DIR=$(SOLVE_OUT_DIR)/csv" "Directory CSV solve_*"
	@printf "  %-60s | %s\n" "SOLVE_SOLUTIONS_DIR=$(SOLVE_OUT_DIR)/solutions" "Directory route per backend"
	@printf "  %-60s | %s\n" "SOLVE_MANIFEST=.../manifest.csv" "Manifest usato da solve_pyvrp/solve_seq"
	@printf "  %-60s | %s\n" "SOLVE_MANIFEST_MPI=.../manifest_openmp_mpi.csv" "Manifest usato da solve_mpi"
	@printf "  %-60s | %s\n" "SOLVE_MANIFEST_CUDA=.../manifest_cuda.csv" "Manifest usato da solve_cuda"
	@printf "  %-60s | %s\n" "SOLVE_CLIENTS=1000,2000,4000" "Filtra per numero clienti n (colonna 4 del manifest)"
	@printf "  %-60s | %s\n" "SOLVE_LIMIT=5" "Limita alle prime N righe dopo i filtri (0 = tutte)"
	@printf "  %-60s | %s\n" "SOLVE_PYVRP_RUNTIME_S=10" "Budget tempo per istanza PyVRP (secondi)"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_RUNTIME_S=300" "Budget massimo seq per run (secondi)"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_RUNTIME=60" "Alias compatibile di SOLVE_SEQ_RUNTIME_S"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_STAGNATION_EPOCHS=0" "Stop seq dopo N epoche senza miglioramento relativo significativo (0=off)"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_MIN_REL_IMPROVEMENT=0.1" "Percentuale minima di miglioramento relativo per epoca (0.1 = 0.1%%)"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_M=0" "Override m (formiche) per solve_seq; 0=usa manifest"
	@printf "  %-60s | %s\n" "SOLVE_SEQ_REPEATS=1" "Ripetizioni per istanza nel solve_seq"
	@printf "  %-60s | %s\n" "SOLVE_MPI_RUNTIME_S=300" "Budget massimo MPI+OpenMP per run (secondi)"
	@printf "  %-60s | %s\n" "SOLVE_MPI_STAGNATION_EPOCHS=0" "Stop MPI per stagnazione (0 usa il fallback backend di 100 epoche)"
	@printf "  %-60s | %s\n" "SOLVE_MPI_MIN_REL_IMPROVEMENT=0.1" "Percentuale minima di miglioramento relativo per epoca MPI (0.1 = 0.1%%)"
	@printf "  %-60s | %s\n" "SOLVE_MPI_REPEATS=1" "Ripetizioni per istanza nel solve_mpi"
	@printf "  %-60s | %s\n" "SOLVE_MPI_M=0" "Override formiche MPI (0=usa il manifest)"
	@printf "  %-60s | %s\n" "SOLVE_MPI_FIXED_EPOCHS=0" "Epoche fisse MPI per benchmark riproducibili"
	@printf "  %-60s | %s\n" "SOLVE_PYVRP_SEED=1234" "Seed PyVRP"
	@printf "  %-60s | %s\n" "SOLVE_MPI_RANKS=2" "Numero processi MPI per solve_mpi"
	@printf "  %-60s | %s\n" "SOLVE_MPI_OMP_THREADS=2" "Thread OpenMP per rank MPI"
	@printf "  %-60s | %s\n" "SOLVE_MPI_LAUNCHER=auto" "Launcher MPI: auto|mpirun|srun"
	@printf "  %-60s | %s\n" "SOLVE_CUDA_RUNTIME_S=300" "Budget massimo CUDA per run (secondi)"
	@printf "  %-60s | %s\n" "SOLVE_CUDA_STAGNATION_EPOCHS=0" "Stop CUDA dopo N epoche senza miglioramento (0=off)"
	@printf "  %-60s | %s\n" "SOLVE_CUDA_MIN_REL_IMPROVEMENT=0.1" "Soglia minima di miglioramento relativo CUDA"
	@printf "  %-60s | %s\n" "SOLVE_CUDA_M=0" "Override formiche CUDA (0=usa il manifest)"
	@printf "  %-60s | %s\n" "SOLVE_CUDA_REPEATS=1" "Ripetizioni per istanza nel solve_cuda"
	@printf "  %-60s | %s\n" "SOLVE_MEMORY_GROWTH_CLIENTS=4000,...,64000" "Taglie del test crescita memoria non-CUDA"
	@printf "  %-60s | %s\n\n" "SOLVE_MEMORY_GROWTH_REPEATS=3" "Ripetizioni del test crescita memoria non-CUDA"
	@printf "VARIABILI PER exp_*:\n"
	@printf "  %-60s | %s\n" "EXP_REPEATS=5" "Ripetizioni per ogni punto sperimentale"
	@printf "  %-60s | %s\n" "EXP_RUNTIME_S=300" "Limite di ogni run in secondi"
