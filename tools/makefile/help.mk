help:
	@printf "\n"
	@printf "\033[1;36m================================================================================\033[0m\n"
	@printf "\033[1;32m                     VEHICLE ROUTING PROBLEM - MAKE HELP                        \033[0m\n"
	@printf "\033[1;36m================================================================================\033[0m\n\n"
	@printf "\033[1;34m[1] TARGET DI COMPILAZIONE (BUILD)\033[0m\n"
	@printf "  \033[32mmake all\033[0m             - Compila tutti i solver (\033[33mseq.out\033[0m, \033[33mopenmp_mpi.out\033[0m, \033[33mcuda.out\033[0m)\n"
	@printf "  \033[32mmake seq\033[0m             - Compila solo il solver sequenziale -> \033[33mseq.out\033[0m\n"
	@printf "  \033[32mmake openmp_mpi\033[0m      - Compila solo il solver MPI+OpenMP -> \033[33mopenmp_mpi.out\033[0m\n"
	@printf "  \033[32mmake cuda\033[0m            - Compila solo il solver CUDA -> \033[33mcuda.out\033[0m\n"
	@printf "  \033[32mmake clean\033[0m           - Pulisce binari, oggetti, coverage e file temporanei\n"
	@printf "  \033[32mmake debug\033[0m           - Compila i target in modalità Debug (-g, -DDEBUG)\n\n"
	@printf "\033[1;34m[2] GENERAZIONE PROBLEMI (ISTANZE)\033[0m\n"
	@printf "  \033[32mmake generate_problems\033[0m - Genera istanze .vrp di benchmark + relativi manifest\n"
	@printf "  \033[32mmake generate_problems_big\033[0m - Genera istanze di taglia grande non-CUDA (4k..32k)\n"
	@printf "  \033[32mmake generate_clean\033[0m    - Rimuove tutte le istanze e i manifest generati\n\n"
	@printf "\033[1;34m[3] ESECUZIONE SOLVER DA MANIFEST (PRODUZIONE DATI)\033[0m\n"
	@printf "  \033[32mmake solve_all\033[0m       - Esegue in sequenza tutti i solver (PyVRP, Seq, CUDA, MPI)\n"
	@printf "  \033[32mmake solve_seq\033[0m       - Esegue il solver sequenziale sulle istanze del manifest\n"
	@printf "  \033[32mmake solve_mpi\033[0m       - Esegue il solver parallelo MPI+OpenMP sul manifest\n"
	@printf "  \033[32mmake solve_cuda\033[0m      - Esegue il solver accelerato CUDA sul manifest\n"
	@printf "  \033[32mmake solve_pyvrp\033[0m     - Esegue l'algoritmo di riferimento PyVRP\n\n"
	@printf "\033[1;34m[4] ESPERIMENTI DI SCALING (PROFILAZIONE & PERFORMANCE)\033[0m\n"
	@printf "  \033[32mmake exp_all\033[0m         - Lancia tutti gli esperimenti CPU (strong/weak, OpenMP/MPI/ibrido)\n"
	@printf "  \033[32mmake exp_cuda_all\033[0m    - Lancia esperimenti e confronti specifici per GPU CUDA\n"
	@printf "  \033[32mmake run_scaling_tests\033[0m - Esegue test prestazionali e profilazione ncu su CUDA\n\n"
	@printf "\033[1;34m[5] PRINCIPALI VARIABILI DI CONFIGURAZIONE\033[0m\n"
	@printf "  \033[33mSOLVE_CLIENTS=500,1000\033[0m    - Filtra per taglia n (clienti) da risolvere\n"
	@printf "  \033[33mSOLVE_LIMIT=5\033[0m             - Limita il numero di righe/istanze del manifest da processare\n"
	@printf "  \033[33mSOLVE_SEQ_REPEATS=3\033[0m       - Ripetizioni per istanza (solver sequenziale)\n"
	@printf "  \033[33mSOLVE_MPI_RANKS=4\033[0m         - Processi MPI da allocare\n"
	@printf "  \033[33mSOLVE_MPI_OMP_THREADS=8\033[0m   - Thread OpenMP per ciascun processo MPI\n"
	@printf "  \033[33mCUDA_ARCH=sm_75\033[0m           - Architettura GPU target per nvcc (es. sm_75, sm_80)\n\n"
	@printf "\033[1;34m[6] ESEMPI PRATICI DI UTILIZZO\033[0m\n"
	@printf "  \033[1;35mEsecuzione Sequenziale Locale:\033[0m\n"
	@printf "    make solve_seq SOLVE_CLIENTS=500,1000 SOLVE_SEQ_REPEATS=3 SOLVE_SEQ_RUNTIME_S=300\n\n"
	@printf "  \033[1;35mEsecuzione Parallela MPI+OpenMP:\033[0m\n"
	@printf "    make solve_mpi SOLVE_MPI_RANKS=2 SOLVE_MPI_OMP_THREADS=4 SOLVE_MPI_RUNTIME_S=120\n\n"
	@printf "  \033[1;35mEsecuzione in Batch (su Cluster SLURM):\033[0m\n"
	@printf '    make solve_mpi SOLVE_MPI_RANKS=$$SLURM_NTASKS SOLVE_MPI_OMP_THREADS=32 SOLVE_MPI_LAUNCHER=srun\n'
	@printf "================================================================================\n\n"
