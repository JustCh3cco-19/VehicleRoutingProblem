help:
	@printf "\n"
	@printf "VehicleRoutingProblem - Make Help\n"
	@printf "=================================\n\n"
	@printf "COMANDI ESEMPIO - LOCALE:\n"
	@printf "  make solve_pyvrp SOLVE_CLIENTS=1000,2000,4000,8000 SOLVE_PYVRP_RUNTIME_S=300 SOLVE_PYVRP_SEED=1234\n"
	@printf "  make solve_seq SOLVE_CLIENTS=1000,2000,4000,8000 SOLVE_SEQ_REPEATS=3 SOLVE_SEQ_RUNTIME_S=300 SOLVE_SEQ_STAGNATION_EPOCHS=80 SOLVE_SEQ_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make solve_mpi SOLVE_CLIENTS=1000,2000,4000,8000 SOLVE_MPI_REPEATS=3 SOLVE_MPI_RUNTIME_S=300 SOLVE_MPI_STAGNATION_EPOCHS=80 SOLVE_MPI_MIN_REL_IMPROVEMENT=10 SOLVE_MPI_RANKS=4 SOLVE_MPI_OMP_THREADS=8\n"
	@printf "  make solve_cuda SOLVE_CLIENTS=1000,2000,4000,8000 SOLVE_CUDA_REPEATS=3 SOLVE_CUDA_RUNTIME_S=300 SOLVE_CUDA_STAGNATION_EPOCHS=80 SOLVE_CUDA_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make solve_seq SOLVE_SEQ_REPEATS=3 SOLVE_SEQ_RUNTIME_S=300 SOLVE_SEQ_STAGNATION_EPOCHS=80 SOLVE_SEQ_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make solve_seq && make solve_mpi && make solve_cuda\n\n"
	@printf "COMANDI ESEMPIO - CLUSTER (dentro job allocato):\n"
	@printf "  make solve_seq SOLVE_SEQ_REPEATS=3 SOLVE_SEQ_RUNTIME_S=300 SOLVE_SEQ_STAGNATION_EPOCHS=80 SOLVE_SEQ_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make solve_mpi SOLVE_MPI_REPEATS=3 SOLVE_MPI_RUNTIME_S=300 SOLVE_MPI_STAGNATION_EPOCHS=80 SOLVE_MPI_MIN_REL_IMPROVEMENT=10 SOLVE_MPI_RANKS=$${SLURM_NTASKS:-4} SOLVE_MPI_OMP_THREADS=32 SOLVE_MPI_LAUNCHER=mpirun\n"
	@printf "  make solve_cuda SOLVE_CUDA_REPEATS=3 SOLVE_CUDA_RUNTIME_S=300 SOLVE_CUDA_STAGNATION_EPOCHS=80 SOLVE_CUDA_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make generate_problems GEN_CLIENTS=500,1000,2000,4000,8000,16000,32000,64000\n"
	@printf "  make generate_problems_big\n"
	@printf "  make solve_pyvrp SOLVE_CLIENTS=1000,2000 SOLVE_PYVRP_RUNTIME_S=300\n"
	@printf "  make solve_seq   SOLVE_CLIENTS=1000,2000 SOLVE_SEQ_RUNTIME_S=300 SOLVE_SEQ_STAGNATION_EPOCHS=80 SOLVE_SEQ_MIN_REL_IMPROVEMENT=10 SOLVE_SEQ_REPEATS=3\n"
	@printf "  make solve_cuda  SOLVE_CLIENTS=1000,2000 SOLVE_CUDA_REPEATS=3 SOLVE_CUDA_RUNTIME_S=300 SOLVE_CUDA_STAGNATION_EPOCHS=80 SOLVE_CUDA_MIN_REL_IMPROVEMENT=10\n"
	@printf "  make solve_mpi   SOLVE_CLIENTS=4000,8000 SOLVE_MPI_RANKS=4 SOLVE_MPI_OMP_THREADS=8 SOLVE_MPI_RUNTIME_S=300 SOLVE_MPI_STAGNATION_EPOCHS=80 SOLVE_MPI_MIN_REL_IMPROVEMENT=10 SOLVE_MPI_REPEATS=3\n"
	@printf "  make solve_memory_growth_non_cuda SOLVE_MPI_RANKS=4 SOLVE_MPI_OMP_THREADS=8\n"
	@printf "  make exp_strong_openmp\n"
	@printf "  make exp_weak_openmp\n"
	@printf "  make exp_strong_mpi\n"
	@printf "  make exp_strong_hybrid\n"
	@printf "  make exp_weak_mpi\n"
	@printf "  make exp_weak_hybrid\n"
	@printf "  make exp_cuda_all\n"
	@printf "  make run_scaling_tests\n"
	@printf "  make exp_all\n"
	@printf "  make solve_all   SOLVE_CLIENTS=1000,2000\n\n"
	@printf "TARGET GENERAZIONE PROBLEMI:\n"
	@printf "  %-42s | %s\n" "generate_problems" "Genera istanze .vrp + manifest.csv + manifest_openmp_mpi.csv + manifest_cuda.csv"
	@printf "  %-42s | %s\n" "generate_problems_big" "Profilo istanze grandi non-CUDA (4k..32k)"
	@printf "  %-42s | %s\n\n" "generate_clean" "Rimuove istanze/manifest generati in GEN_INST_DIR"
	@printf "TARGET BUILD:\n"
	@printf "  %-42s | %s\n" "all" "Compila tutti i solver -> seq + MPI+OpenMP + CUDA"
	@printf "  %-42s | %s\n" "seq" "Compila solo il solver sequenziale -> aco_vrp_seq.out"
	@printf "  %-42s | %s\n" "openmp_mpi" "Compila il solver MPI+OpenMP -> aco_vrp_openmp_mpi.out"
	@printf "  %-42s | %s\n" "cuda" "Compila il solver CUDA -> aco_vrp_cuda.out"
	@printf "  %-42s | %s\n" "debug" "Ricompila con flag -DDEBUG"
	@printf "  %-42s | %s\n\n" "clean" "Pulisce binari, oggetti, coverage e artefatti CUDA intermedi"
	@printf "TARGET DOCUMENTAZIONE PDF:\n"
	@printf "  %-42s | %s\n" "pdfs" "Compila tutti i documenti LaTeX principali"
	@printf "  %-42s | %s\n\n" "clean_pdfs" "Rimuove i PDF generati e gli intermedi LaTeX"
	@printf "TARGET SOLVE DA MANIFEST (PRODUZIONE DATI):\n"
	@printf "  %-42s | %s\n" "solve_prepare" "Crea cartelle output e verifica esistenza manifest"
	@printf "  %-42s | %s\n" "solve_pyvrp" "Legge SOLVE_MANIFEST, risolve con PyVRP, salva CSV + route txt"
	@printf "  %-42s | %s\n" "solve_seq" "Legge SOLVE_MANIFEST, esegue solver sequenziale, salva CSV + route txt"
	@printf "  %-42s | %s\n" "solve_cuda" "Legge SOLVE_MANIFEST_CUDA, esegue solver CUDA, salva CSV + route txt"
	@printf "  %-42s | %s\n" "solve_mpi" "Legge SOLVE_MANIFEST_MPI, esegue solver MPI, salva CSV + route txt"
	@printf "  %-42s | %s\n" "solve_memory_growth_non_cuda" "Esegue seq+mpi con ripetizioni e CSV con max_rss_gb"
	@printf "  %-42s | %s\n\n" "solve_all" "Esegue in sequenza: solve_pyvrp, solve_seq, solve_cuda, solve_mpi"
