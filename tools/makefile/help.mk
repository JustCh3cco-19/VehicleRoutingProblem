	@printf "  %-60s | %s\n" "EXP_STRONG_MPI_N=16000" "N fisso per strong MPI"
	@printf "  %-60s | %s\n" "EXP_STRONG_MPI_RANKS='1 2 4'" "Rank/nodi MPI da testare"
	@printf "  %-60s | %s\n" "EXP_STRONG_MPI_OMP_THREADS=32" "OMP fisso per strong MPI"
	@printf "  %-60s | %s\n" "EXP_STRONG_HYBRID_N=16000" "N fisso per strong ibrido MPI+OpenMP"
