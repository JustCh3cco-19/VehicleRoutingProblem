	@printf "  %-60s | %s\n" "EXP_WEAK_MPI_PAIRS='1 1000 2 2000 4 4000'" "Coppie rank N per weak scaling MPI"
	@printf "  %-60s | %s\n\n" "EXP_WEAK_MPI_OMP_THREADS=32" "OMP fisso per weak MPI"
	@printf "  %-60s | %s\n\n" "EXP_WEAK_HYBRID_TRIPLETS='1 32 1000 ... 4 32 4000'" "Triple rank thread N per weak ibrido"
