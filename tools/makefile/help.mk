	@printf "  %-42s | %s\n" "exp_strong_openmp" "Strong scaling OpenMP: N fisso, ranks=1, thread variabili"
	@printf "  %-42s | %s\n" "exp_strong_openmp_n8000_m256" "Strong OpenMP specializzato: n=8000, m=256, thread 1..16"
