	@printf "  %-60s | %s\n" "GEN_INST_DIR=instances/generated_benchmark" "Directory dove scrivere .vrp e manifest"
	@printf "  %-60s | %s\n" "GEN_CLIENTS=500,1000,2000,4000,8000,16000,32000,64000" "Taglie n da generare (CSV separato da virgole)"
	@printf "  %-60s | %s\n" "GEN_SEED_BASE=19000" "Seed base; per ogni istanza incrementa di 1"
	@printf "  %-60s | %s\n" "GEN_GRID=100" "Griglia coordinate passata al generatore"
