	@printf "  %-60s | %s\n" "EXP_MAX_CLUSTER_NODES=4" "Numero massimo nodi MPI da usare negli auto-scaling"
	@printf "  %-60s | %s\n" "EXP_MAX_CPUS_PER_TASK=32" "Massimo thread OpenMP per task"
	@printf "  %-60s | %s\n" "EXP_MAX_TOTAL_CORES=128" "Massimo asse x delle curve strong"
	@printf "  %-60s | %s\n" "EXP_WEAK_BASE_N_PER_WORKER=1000" "Base N per worker usata nelle modalita auto weak"
